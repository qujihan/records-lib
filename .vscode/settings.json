{
    "tinymist.previewFeature": "enable",
    "tinymist.outputPath": "${fileWorkspaceFolder}/example.pdf",
    "tinymist.rootPath": "${fileWorkspaceFolder}",
    "[typst]": {
        "editor.wordWrap": "bounded",
        "editor.wordWrapColumn": 100,
    },
    "trae.enableCodelens": {
        "enableInlineDocumentation": false,
        "enableInlineUnitTest": false,
        "enableInlineExplain": false
    },
    "trae.enableInlineCommand": false
}